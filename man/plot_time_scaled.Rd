\name{plot_time_scaled}
\alias{plot_time_scaled}
\title{Plot a time-scaled phylogenetic tree}
\usage{
plot_time_scaled(phy, expand = 1.08, ...)
}
\arguments{
  \item{phy}{\code{phylo} object.}
  \item{expand}{Horizontal padding factor.}
  \item{...}{Unused; reserved for extension.}
}
\value{
Invisibly returns \code{phy}.
}
\description{
Plots a tree with a horizontal time axis.
}
