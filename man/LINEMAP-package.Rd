\name{LINEMAP-package}
\alias{LINEMAP-package}
\alias{LINEMAP}
\title{LINEMAP: Lineage Map Simulation and Phylogenetic Trees}
\description{
Simulates cell lineage histories with guide-RNA barcode dynamics, builds
phylogenetic trees from simulated edge tables, and provides plotting and
subtree sampling helpers.
}
